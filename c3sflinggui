-- Live HP + count badge updater
task.spawn(function()
    while SG.Parent do
        for name,data in pairs(Checkmarks) do
            local pl=Players:FindFirstChild(name); if not pl then continue end
            local hum=pl.Character and pl.Character:FindFirstChildOfClass("Humanoid")
            if not hum then data.hpFill.Size=UDim2.new(0,0,1,0); data.hpTxt.Text="☠"; data.hpTxt.TextColor3=MUTE; continue end
            local pct=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
            local col=pct>0.5 and GREEN or pct>0.25 and YELLOW or RED
            data.hpFill.Size=UDim2.new(pct,0,1,0); data.hpFill.BackgroundColor3=col
            data.hpTxt.Text=math.floor(hum.Health).."hp"; data.hpTxt.TextColor3=col
            local cnt=S.FlingCounts[name] or 0
            data.cntBadge.Text=cnt>0 and "×"..cnt or ""
        end
        task.wait(0.5)
    end
end)

